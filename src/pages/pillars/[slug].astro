---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const pillars = await getCollection('pillars');
  return pillars.map(entry => ({
    params: { slug: entry.id },
    props: { entry }, // This passes 'entry' to the page
  }));
}

const { entry } = Astro.props; 

const { Content } = await render(entry);
const allProjects = await getCollection('projects');
const projectsInPillar = allProjects.filter(p => p.data.pillar === entry.id);
---

<Layout title={`${entry.data.title} | NEXUS`}>
  <article class="case-study">
    <header class="project-header">
      <div class="meta-row">
        <span class="category-tag">SYSTEM_PILLAR // 0{entry.data.order}</span>
        <span class="status-indicator">STATUS: ACTIVE_CASE_STUDY</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="focus-statement">{entry.data.focus}</p>
    </header>

    <div class="nexus-rule"></div>

    <section class="project-grid">
      {projectsInPillar.map(project => (
        <a href={`/projects/${project.id}`} class="pillar-card" style="text-decoration: none;">
          <h3>{project.data.title}</h3>
          <p style="color: #aaa;">{project.data.description}</p>
        </a>
      ))}
    </section>
    
    <footer class="project-footer">
      <div class="tags">
        {entry.data.tags.map(tag => <span class="tag">#{tag}</span>)}
      </div>
      <a href="/" class="back-link">
        <span class="arrow">←</span> RETURN TO SYSTEMS OVERVIEW
      </a>
    </footer>
  </article>
</Layout>

<style>
  .case-study { margin: 0 auto; padding: 80px 20px; }
  .project-header { margin-bottom: 60px; }
  .meta-row { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 0.7rem; color: rgba(255,255,255,0.3); letter-spacing: 2px; margin-bottom: 20px; }
  h1 { font-family: var(--font-brand); font-size: clamp(2rem, 5vw, 3.5rem); margin: 0; background: var(--nexus-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1.2; }
  .focus-statement { font-size: 1.4rem; font-weight: 200; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.5rem; margin-top: 10px; }
  .nexus-rule { height: 1px; background: linear-gradient(to right, var(--nexus-purple), var(--nexus-orange), transparent); margin: 40px 0; border: 0; }
  .project-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }
  .project-footer { margin-top: 100px; padding-top: 40px; border-top: 1px solid rgba(255,255,255,0.1); }
  .tag { font-family: var(--font-mono); font-size: 0.75rem; color: var(--nexus-orange); margin-right: 25px; letter-spacing: 1px; }
  .back-link { display: inline-block; margin-top: 60px; color: var(--text-light); text-decoration: none; font-family: var(--font-mono); font-size: 0.8rem; letter-spacing: 2px; opacity: 0.5; transition: opacity 0.3s ease; }
  .back-link:hover { opacity: 1; color: var(--nexus-orange); }
</style>