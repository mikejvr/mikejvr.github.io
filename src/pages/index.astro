---
import { getCollection, render } from 'astro:content';

const pillars = await getCollection('pillars');
const sortedPillars = pillars.sort((a, b) => a.data.order - b.data.order);

// Render markdown content for each pillar
const pillarsWithContent = await Promise.all(
  sortedPillars.map(async (pillar) => {
    const { Content } = await render(pillar);
    return { ...pillar, Content };
  })
);

const expertiseStory = "I bridge the gap between creative vision and technical execution. With over two decades of experience, I provide a full-service design infrastructure—transforming complex organizational needs into cohesive visual systems.";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>NEXUS | Technical Design & Creative Systems</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Michroma&family=Roboto+Mono:wght@300;400&family=Saira+Extra+Condensed:wght@200;300;400&display=swap" rel="stylesheet">

		<style>
			:root {
				--nexus-purple: #2D1B69;
				--nexus-orange: #FF6B35;
				--nexus-gradient: linear-gradient(135deg, #2D1B69 0%, #FF6B35 100%);
				
				--pillar-blue: #005A9C;
				--pillar-teal: #00A896;
				--pillar-red: #C8102E;

				--font-brand: 'Michroma', sans-serif;
				--font-tagline: 'Saira Extra Condensed', sans-serif;
				--font-mono: 'Roboto Mono', monospace;
				
				--bg-dark: #0a0a0c;
				--text-light: #f4f4f9;
			}

			body {
				background-color: var(--bg-dark);
				
				/* The NEXUS Structural Grid */
				background-image: 
					linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
				background-size: 40px 40px; /* The scale of the grid squares */
				background-position: center top;
				
				color: var(--text-light);
				font-family: var(--font-tagline);
				max-width: 1000px;
				margin: 0 auto;
				padding: 0 20px;
				line-height: 1.6;
				
				/* Smooth rendering for technical precision */
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			/* Header Styles */
			.nexus-header {
				text-align: center;
				padding: 100px 20px;
				border-bottom: 1px solid rgba(255,255,255,0.1);
			}
			.logo-container {
				display: flex;
				justify-content: center;
				margin-bottom: 20px;
			}

			.brand-logo {
				width: 120px; /* Adjust based on your preference */
				height: auto;
				/* If using the dark-mode version on a dark background, 
					ensure your PNG has a transparent background */
				filter: drop-shadow(0 0 15px rgba(255, 107, 53, 0.2)); /* Subtle Orange Glow */
			}
			.brand-mark {
				font-family: var(--font-brand);
				font-size: 5rem;
				background: var(--nexus-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				margin-bottom: 0;
			}
			h1.brand-name {
				font-family: var(--font-brand);
				font-size: 3.5rem;
				margin: 0;
				letter-spacing: 1rem;
				line-height: 1.2;
			}
			.tagline {
				font-family: var(--font-tagline);
				font-weight: 200;
				text-transform: uppercase;
				letter-spacing: 0.6rem;
				color: rgba(255,255,255,0.5);
				margin-top: 10px;
			}

			/* Content Sections */
			.expertise {
				font-family: var(--font-tagline);
				font-size: 1.4rem;
				font-weight: 300;
				background: rgba(255,255,255,0.03);
				padding: 40px;
				border-left: 2px solid var(--nexus-orange);
				margin: 60px 0;
			}

			.portfolio-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 30px;
			}

			.pillar-card {
				background: rgba(10, 10, 12, 0.8); /* Slightly transparent dark background */
				backdrop-filter: blur(10px); /* Creates a frosted glass effect over the grid */
				border: 1px solid rgba(255,255,255,0.05);
				padding: 40px;
				border-radius: 4px;
				transition: all 0.3s ease;
				box-shadow: 0 10px 30px rgba(0,0,0,0.5); /* Depth shadow */
			}

			.pillar-card:hover {
				background: rgba(255,255,255,0.05);
				transform: translateX(10px);
			}

			.pillar-category {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.2rem;
				display: block;
				margin-bottom: 10px;
			}

			/* 1. Target the nodes in the SVG */
				.nexus-node {
					fill: #FF6B35;
					filter: drop-shadow(0 0 8px #FF6B35);
					transform-origin: center;
					transform-box: fill-box;
				}

			.circuit-segment {
				animation: circuitPulse 3s infinite ease-in-out;
				transform-origin: center;
				transform-box: fill-box;
			}

			/* Staggering the segments creates the "Wave" effect */
			.circuit-segment:nth-child(1) { animation-delay: 0s; }
			.circuit-segment:nth-child(2) { animation-delay: 0.5s; }
			.circuit-segment:nth-child(3) { animation-delay: 1.0s; }
			.circuit-segment:nth-child(4) { animation-delay: 1.5s; }
			.circuit-segment:nth-child(5) { animation-delay: 2.0s; }
			.circuit-segment:nth-child(6) { animation-delay: 2.5s; }


			@keyframes circuitPulse {
				0%, 100% { transform: scale(1); opacity: 0.6; }
				50% { transform: scale(1.05); opacity: 1; }
			}
			.brand-logo-svg {
				width: 140px;
				height: auto;
				margin-bottom: 20px;
				transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
			}

			.logo-container:hover .brand-logo-svg {
				transform: scale(1.05);
			}

			.fil0 { fill: #FF6B35; } /* Vibrant Electric Orange */
			.fil1 { fill: #2D1B69; } /* Deep Tech Purple */
			.fil2 { fill: #FF6B35; } /* Nodes (Orange) */


			h3 { font-family: var(--font-brand); font-size: 1.2rem; margin: 10px 0; }

			.content { font-size: 0.95rem; color: #aaa; }

			/* Footer Styles */
			.structural-summary { margin-top: 120px; padding-bottom: 60px; font-family: var(--font-mono); font-size: 0.75rem; color: #444; }
			.nexus-rule { border: 0; height: 1px; background: linear-gradient(to right, var(--nexus-purple), var(--nexus-orange), transparent); margin-bottom: 40px; }
			.specs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
			.spec-item .label { color: var(--nexus-orange); margin-right: 8px; }
			.spec-item .value { color: #888; }
			.copyright { font-family: var(--font-tagline); text-transform: uppercase; letter-spacing: 0.3rem; margin-top: 60px; opacity: 0.3; }
		</style>
	</head>
	<body>
		<header class="nexus-header">
			<div class="logo-container">
				<svg class="brand-logo-svg" viewBox="0 0 825 1513" overflow="visible" xmlns="http://www.w3.org/2000/svg">
					<g id="Layer_x0020_2">
						<g id="_2343506256496" class="circuit-segment">
							<path class="fil0" d="M396 41l23 0c0,387 0,369 0,628l-23 0 0 -628z"/>
							<circle class="nexus-node" cx="407" cy="41" r="41"/>
						</g>
						<g id="_2343506256272" class="circuit-segment">
							<polygon class="fil0" points="365,640 348,640 348,377 252,273 265,262 365,370 "/>
							<circle class="nexus-node" cx="259" cy="266" r="31"/>
						</g>
						<g id="_2343506260240" class="circuit-segment">
							<polygon class="fil0" points="451,972 469,972 469,1204 564,1307 552,1319 451,1211 "/>
							<circle class="nexus-node" cx="557" cy="1314" r="31"/>
						</g>
						<g id="_2343506261168" class="circuit-segment">
							<polygon class="fil0" points="420,1007 398,1043 345,1128 330,1119 398,1011 398,943 420,943 "/>
							<circle class="nexus-node" cx="337" cy="1124" r="25"/>
						</g>
						<g id="_2343506262032" class="circuit-segment">
							<path class="fil0" d="M420 1472l-22 0c0,-330 0,-294 0,-529l22 0 0 529z"/>
							<circle class="nexus-node" cx="409" cy="1472" r="41"/>
						</g>
						<g id="_2343506261136" class="circuit-segment">
							<polygon class="fil0" points="396,600 419,569 483,467 497,476 419,602 419,669 396,669 "/>
							<circle class="nexus-node" cx="490" cy="471" r="25"/>
						</g>
					</g>
					<g id="Layer_x0020_3">
						<path class="fil1" d="M0 442l825 914 -1 82 -768 -852 0 859 -56 0 0 -1003zm239 845l-56 0 0 -480 56 52 0 428zm347 -1022l55 0 0 564 -55 -52 0 -512zm239 929l-825 -914 1 -82 768 852 0 -949 56 0 0 1093z"/>
					</g>
				</svg>
			</div>
			<h1 class="brand-name">NEXUS</h1>
			<p class="tagline">TECHNICAL DESIGN & CREATIVE SYSTEMS</p>
		</header>		
		<section class="expertise">
			<p>{expertiseStory}</p>
		</section>

		<div class="portfolio-grid">
			{pillarsWithContent.map(pillar => {
				const getAccent = (title) => {
					if (title.includes("Brand") || title.includes("Publication")) return "var(--pillar-red)";
					if (title.includes("Web") || title.includes("Digital")) return "var(--pillar-teal)";
					if (title.includes("Technical") || title.includes("Environmental")) return "var(--pillar-blue)";
					return "var(--pillar-blue)";
				};

				const accent = getAccent(pillar.data.title);

				return (
					<div class="pillar-card" style={`border-left: 2px solid ${accent}`}>
						<span class="pillar-category" style={`color: ${accent}`}>
							{pillar.data.title.toUpperCase()}
						</span>
						<h3>{pillar.data.focus}</h3>
						<div class="content">
							<pillar.Content />
						</div>
					</div>
				);
			})}
		</div>

		<footer class="structural-summary">
			<hr class="nexus-rule" />
			<div class="specs-grid">
				<div class="spec-item"><span class="label">BUILD:</span><span class="value">STABLE // PROD</span></div>
				<div class="spec-item"><span class="label">ENGINE:</span><span class="value">ASTRO_V4_STATIC</span></div>
				<div class="spec-item"><span class="label">PIPELINE:</span><span class="value">GH_ACTIONS_DEPLOY</span></div>
				<div class="spec-item"><span class="label">LOCATION:</span><span class="value">ATX_USA // 30.2672° N, 97.7431° W</span></div>
			</div>
			<p class="copyright">© 2026 NEXUS | ALL RIGHTS RESERVED.</p>
		</footer>
	</body>
</html>