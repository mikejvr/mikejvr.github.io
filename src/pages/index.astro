---
import { getCollection, render } from 'astro:content';

const pillars = await getCollection('pillars');
const sortedPillars = pillars.sort((a, b) => a.data.order - b.data.order);

// Render markdown content for each pillar
const pillarsWithContent = await Promise.all(
  sortedPillars.map(async (pillar) => {
    const { Content } = await render(pillar);
    return { ...pillar, Content };
  })
);

const expertiseStory = "I bridge the gap between creative vision and technical execution. With over two decades of experience, I provide a full-service design infrastructure—transforming complex organizational needs into cohesive visual systems.";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>NEXUS | Technical Design & Creative Systems</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Michroma&family=Roboto+Mono:wght@300;400&family=Saira+Extra+Condensed:wght@200;300;400&display=swap" rel="stylesheet">

		<style>
			:root {
				--nexus-purple: #2D1B69;
				--nexus-orange: #FF6B35;
				--nexus-gradient: linear-gradient(135deg, #2D1B69 0%, #FF6B35 100%);
				
				--pillar-blue: #005A9C;
				--pillar-teal: #00A896;
				--pillar-red: #C8102E;

				--font-brand: 'Michroma', sans-serif;
				--font-tagline: 'Saira Extra Condensed', sans-serif;
				--font-mono: 'Roboto Mono', monospace;
				
				--bg-dark: #0a0a0c;
				--text-light: #f4f4f9;
			}

			body {
				background-color: var(--bg-dark);
				
				/* The NEXUS Structural Grid */
				background-image: 
					linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
				background-size: 40px 40px; /* The scale of the grid squares */
				background-position: center top;
				
				color: var(--text-light);
				font-family: var(--font-tagline);
				max-width: 1000px;
				margin: 0 auto;
				padding: 0 20px;
				line-height: 1.6;
				
				/* Smooth rendering for technical precision */
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			/* Header Styles */
			.nexus-header {
				text-align: center;
				padding: 100px 20px;
				border-bottom: 1px solid rgba(255,255,255,0.1);
			}
			.logo-container {
				display: flex;
				justify-content: center;
				margin-bottom: 20px;
			}

			.brand-logo {
				width: 120px; /* Adjust based on your preference */
				height: auto;
				/* If using the dark-mode version on a dark background, 
					ensure your PNG has a transparent background */
				filter: drop-shadow(0 0 15px rgba(255, 107, 53, 0.2)); /* Subtle Orange Glow */
			}
			.brand-mark {
				font-family: var(--font-brand);
				font-size: 5rem;
				background: var(--nexus-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				margin-bottom: 0;
			}
			h1.brand-name {
				font-family: var(--font-brand);
				font-size: 3.5rem;
				margin: 0;
				letter-spacing: 1rem;
				line-height: 1.2;
			}
			.tagline {
				font-family: var(--font-tagline);
				font-weight: 200;
				text-transform: uppercase;
				letter-spacing: 0.6rem;
				color: rgba(255,255,255,0.5);
				margin-top: 10px;
			}

			/* Content Sections */
			.expertise {
				font-family: var(--font-tagline);
				font-size: 1.4rem;
				font-weight: 300;
				background: rgba(255,255,255,0.03);
				padding: 40px;
				border-left: 2px solid var(--nexus-orange);
				margin: 60px 0;
			}

			.portfolio-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 30px;
			}

			.pillar-card {
				background: rgba(10, 10, 12, 0.8); /* Slightly transparent dark background */
				backdrop-filter: blur(10px); /* Creates a frosted glass effect over the grid */
				border: 1px solid rgba(255,255,255,0.05);
				padding: 40px;
				border-radius: 4px;
				transition: all 0.3s ease;
				box-shadow: 0 10px 30px rgba(0,0,0,0.5); /* Depth shadow */
			}

			.pillar-card:hover {
				background: rgba(255,255,255,0.05);
				transform: translateX(10px);
			}

			.pillar-category {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.2rem;
				display: block;
				margin-bottom: 10px;
			}
			/* 1. Target the nodes in the SVG */
			.nexus-node {
				fill: #FF6B35; /* Electric Orange */
				filter: drop-shadow(0 0 5px #FF6B35);
				animation: circuitPulse 4s infinite ease-in-out;
				transform-origin: center;
				}

			/* Staggered timing for technical complexity */
			.nexus-node:nth-child(even) { animation-delay: 2s; }

				@keyframes circuitPulse {
				0%, 100% {
					opacity: 0.8;
					transform: scale(1);
					filter: drop-shadow(0 0 5px #FF6B35);
				}
				50% {
					opacity: 1;
					transform: scale(1.15); /* Subtle expansion */
					filter: drop-shadow(0 0 15px #FF6B35);
				}
			}

			.brand-logo-svg {
				width: 140px;
				height: auto;
				margin-bottom: 20px;
				transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
			}

			.logo-container:hover .brand-logo-svg {
				transform: scale(1.05);
			}

			.fil0 { fill: #FF6B35; } /* Vibrant Electric Orange */
			.fil1 { fill: #2D1B69; } /* Deep Tech Purple */
			.fil2 { fill: #FF6B35; } /* Nodes (Orange) */


			h3 { font-family: var(--font-brand); font-size: 1.2rem; margin: 10px 0; }

			.content { font-size: 0.95rem; color: #aaa; }

			/* Footer Styles */
			.structural-summary { margin-top: 120px; padding-bottom: 60px; font-family: var(--font-mono); font-size: 0.75rem; color: #444; }
			.nexus-rule { border: 0; height: 1px; background: linear-gradient(to right, var(--nexus-purple), var(--nexus-orange), transparent); margin-bottom: 40px; }
			.specs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
			.spec-item .label { color: var(--nexus-orange); margin-right: 8px; }
			.spec-item .value { color: #888; }
			.copyright { font-family: var(--font-tagline); text-transform: uppercase; letter-spacing: 0.3rem; margin-top: 60px; opacity: 0.3; }
		</style>
	</head>
	<body>
		<header class="nexus-header">
			<div class="logo-container">
				<svg class="brand-logo-svg" viewBox="0 0 825 1513" xmlns="http://www.w3.org/2000/svg">
					<g id="Layer_x0020_2">
					<g id="_2343475956288">
					<g>
						<path class="fil0" d="M451 995l18 0 0 209 75 82c4,-2 8,-3 13,-3 17,0 31,14 31,31 0,17 -14,31 -31,31 -17,0 -31,-14 -31,-31 0,-6 2,-12 5,-17l-80 -86 0 -216z"/>
						<path class="fil0" d="M420 1434c16,5 28,20 28,38 0,21 -17,38 -38,38 -21,0 -39,-17 -39,-38 0,-17 11,-32 27,-37l0 -392 -41 66c3,4 5,9 5,15 0,13 -11,24 -25,24 -13,0 -24,-11 -24,-24 0,-14 11,-24 24,-24 2,0 4,0 5,0l56 -89 0 -68 22 0 0 491z"/>
					</g>
					<g>
						<path class="fil0" d="M365 640l-17 0 0 -263 -76 -82c-4,1 -8,2 -13,2 -17,0 -30,-13 -30,-30 0,-17 13,-31 30,-31 17,0 31,14 31,31 0,6 -2,12 -5,16l80 87 0 270z"/>
						<path class="fil0" d="M396 77c-16,-4 -28,-19 -28,-37 0,-21 17,-38 38,-38 22,0 39,17 39,38 0,17 -11,32 -26,37l0 492 52 -83c-3,-4 -5,-6 -5,-15 0,-10 11,-24 24,-24 13,0 24,11 24,24 0,13 -16,24 -24,24 -7,0 -3,0 -5,0l-66 107 0 67 -23 0 0 -592z"/>
					</g>
					</g>
					<g id="_2343475958592">
					<g>
						<polygon class="fil1" points="0,442 825,1356 824,1438 56,586 56,1445 0,1445 "/>
						<polygon class="fil1" points="239,1287 183,1287 183,807 239,859 "/>
					</g>
					<g>
						<polygon class="fil1" points="825,1194 0,280 1,198 769,1050 769,101 825,101 "/>
						<polygon class="fil1" points="586,265 641,265 641,829 586,777 "/>
					</g>
					</g>
					<g id="_2343475960256">
					<circle class="fil2 nexus-node" cx="407" cy="41" r="41"/>
					<circle class="fil2 nexus-node" cx="259" cy="266" r="31"/>
					<circle class="fil2 nexus-node" cx="490" cy="471" r="25"/>
					<circle class="fil2 nexus-node" cx="410" cy="1472" r="41"/>
					<circle class="fil2 nexus-node" cx="557" cy="1314" r="31"/>
					<circle class="fil2 nexus-node" cx="337" cy="1124" r="25"/>
					</g>
				</svg>
			</div>
			<h1 class="brand-name">NEXUS</h1>
			<p class="tagline">TECHNICAL DESIGN & CREATIVE SYSTEMS</p>
		</header>		
		<section class="expertise">
			<p>{expertiseStory}</p>
		</section>

		<div class="portfolio-grid">
			{pillarsWithContent.map(pillar => {
				let accent = "var(--pillar-blue)";
				if (pillar.data.title.includes("Digital") || pillar.data.title.includes("Web")) accent = "var(--pillar-teal)";
				if (pillar.data.title.includes("Brand") || pillar.data.title.includes("Publication")) accent = "var(--pillar-red)";

				return (
					<div class="pillar-card" style={`border-left: 2px solid ${accent}`}>
						<span class="pillar-category" style={`color: ${accent}`}>
							// {pillar.data.title.toUpperCase()}
						</span>
						<h3>{pillar.data.focus}</h3>
						<div class="content">
							<pillar.Content />
						</div>
					</div>
				);
			})}
		</div>

		<footer class="structural-summary">
			<hr class="nexus-rule" />
			<div class="specs-grid">
				<div class="spec-item"><span class="label">BUILD:</span><span class="value">STABLE // PROD</span></div>
				<div class="spec-item"><span class="label">ENGINE:</span><span class="value">ASTRO_V4_STATIC</span></div>
				<div class="spec-item"><span class="label">PIPELINE:</span><span class="value">GH_ACTIONS_DEPLOY</span></div>
				<div class="spec-item"><span class="label">LOCATION:</span><span class="value">ATX_USA // 30.2672° N, 97.7431° W</span></div>
			</div>
			<p class="copyright">© 2026 NEXUS | ALL RIGHTS RESERVED.</p>
		</footer>
	</body>
</html>