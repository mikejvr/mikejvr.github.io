---
interface Props { src: string; alt: string; }
const { src, alt } = Astro.props;
const base = src.replace('-600w.webp', '');
---
<a href={`${base}-1600w.webp`} class="expand-trigger" data-alt={alt} style="display: block;">
  <img 
    src={src} 
    srcset={`${src} 600w, ${base}-1200w.webp 1200w`} 
    sizes="(max-width: 768px) 100vw, 300px" 
    alt={alt} 
    loading="lazy" 
  />
</a>