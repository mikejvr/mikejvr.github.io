---
import { getCollection, render } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';

const pillars = await getCollection('pillars');
const sortedPillars = pillars.sort((a, b) => a.data.order - b.data.order);
const pillarsWithContent = await Promise.all(
  sortedPillars.map(async (pillar) => {
    const { Content } = await render(pillar);
    return { ...pillar, Content };
}));

const expertiseStory = "I bridge the gap between creative vision and technical execution. With over two decades of experience, I provide a full-service design infrastructure—transforming complex organizational needs into cohesive visual systems.";
---

<MainLayout title="Technical Design & Creative Systems">
	<header class="nexus-header">
		<h1 class="brand-name">NEXUS</h1>
		<p class="tagline">TECHNICAL DESIGN & CREATIVE SYSTEMS</p>
	</header>

	<section class="expertise">
		<p>{expertiseStory}</p>
	</section>

	<div class="portfolio-grid">
			{pillarsWithContent.map(pillar => {
				const getAccent = (title) => {
					if (title.includes("Brand") || title.includes("Publication")) return "var(--pillar-red)";
					if (title.includes("Web") || title.includes("Digital")) return "var(--pillar-teal)";
					if (title.includes("Technical") || title.includes("Environmental")) return "var(--pillar-blue)";
					return "var(--pillar-blue)";
				};

				const accent = getAccent(pillar.data.title);

				return (
					<a href={`/pillars/${pillar.id}`} style="text-decoration: none; color: inherit;">
						<div class="pillar-card" style={`border-left: 2px solid ${accent}`}>
							<span class="pillar-category" style={`color: ${accent}`}>
								{pillar.data.title.toUpperCase()}
							</span>
							<h3>{pillar.data.focus}</h3>
							<div class="content">
								<pillar.Content />
							</div>
						</div>
					</a>
				);
			})}
		</div>
	<footer class="structural-summary">
	</footer>
</MainLayout>

