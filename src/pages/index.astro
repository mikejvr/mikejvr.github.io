---
// 1. Import the function to grab your content
import { getCollection } from 'astro:content';

// 2. Fetch the 5 Pillars from your content folder
const pillars = await getCollection('pillars');
// Sort them by the 'order' we put in the markdown
const sortedPillars = pillars.sort((a, b) => a.data.order - b.data.order);

// We need to render the markdown content for each pillar
const pillarsWithContent = await Promise.all(
  sortedPillars.map(async (pillar) => {
    const { Content } = await render(pillar);
    return { ...pillar, Content };
  })
);

const expertiseStory = "I bridge the gap between creative vision and technical execution. With over two decades of experience, I provide a full-service design infrastructure—transforming complex organizational needs into cohesive visual systems.";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Michael Janse van Rensburg | Portfolio</title>
		<style>
			/* A touch of "Graphic Designer" CSS */
			body { font-family: sans-serif; line-height: 1.6; color: #333; max-width: 800px; margin: 40px auto; padding: 0 20px; }
			h1 { border-bottom: 2px solid #000; padding-bottom: 10px; }
			.pillar-card { border: 1px solid #eee; padding: 20px; margin-bottom: 20px; border-radius: 8px; transition: transform 0.2s; }
			.pillar-card:hover { transform: translateY(-5px); border-color: #007bff; }
			.tag { background: #f0f0f0; padding: 4px 8px; border-radius: 4px; font-size: 0.8rem; margin-right: 5px; color: #666; }
			.expertise { font-style: italic; background: #f9f9f9; padding: 20px; border-left: 4px solid #007bff; margin-bottom: 40px; }
		</style>
	</head>
	<body>
		<h1>Design & Infrastructure Portfolio</h1>
		
		<section class="expertise">
			<p>{expertiseStory}</p>
		</section>

		<h2>Core Pillars</h2>
		<div class="portfolio-grid">
    		{pillarsWithContent.map(pillar => (
        		<div class="pillar-card">
            		<h3>{pillar.data.title}</h3>
        			<p><strong>Focus:</strong> {pillar.data.focus}</p>
        			<div class="content">
            			<pillar.Content />
            		</div>
        		</div>
			))}
		</div>
	</body>
</html>
