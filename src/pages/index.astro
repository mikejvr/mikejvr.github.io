---
import { getCollection, render } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';

const pillars = await getCollection('pillars');
const sortedPillars = pillars.sort((a, b) => a.data.order - b.data.order);
const pillarsWithContent = await Promise.all(
  sortedPillars.map(async (pillar) => {
    const { Content } = await render(pillar);
    return { ...pillar, Content };
}));

const expertiseStory = "I bridge the gap between creative vision and technical execution. With over two decades of experience, I provide a full-service design infrastructure—transforming complex organizational needs into cohesive visual systems.";
---

<MainLayout title="Technical Design & Creative Systems">
		<header class="nexus-header">
			<div class="logo-container">
				<svg class="brand-logo-svg" viewBox="0 0 825 1513" overflow="visible" xmlns="http://www.w3.org/2000/svg">
					<g id="Layer_x0020_2">
						<g id="_2343506256496" class="circuit-segment">
							<path class="fil0" d="M396 41l23 0c0,387 0,369 0,628l-23 0 0 -628z"/>
							<circle class="nexus-node" cx="407" cy="41" r="41"/>
						</g>
						<g id="_2343506256272" class="circuit-segment">
							<polygon class="fil0" points="365,640 348,640 348,377 252,273 265,262 365,370 "/>
							<circle class="nexus-node" cx="259" cy="266" r="31"/>
						</g>
						<g id="_2343506260240" class="circuit-segment">
							<polygon class="fil0" points="451,972 469,972 469,1204 564,1307 552,1319 451,1211 "/>
							<circle class="nexus-node" cx="557" cy="1314" r="31"/>
						</g>
						<g id="_2343506261168" class="circuit-segment">
							<polygon class="fil0" points="420,1007 398,1043 345,1128 330,1119 398,1011 398,943 420,943 "/>
							<circle class="nexus-node" cx="337" cy="1124" r="25"/>
						</g>
						<g id="_2343506262032" class="circuit-segment">
							<path class="fil0" d="M420 1472l-22 0c0,-330 0,-294 0,-529l22 0 0 529z"/>
							<circle class="nexus-node" cx="409" cy="1472" r="41"/>
						</g>
						<g id="_2343506261136" class="circuit-segment">
							<polygon class="fil0" points="396,600 419,569 483,467 497,476 419,602 419,669 396,669 "/>
							<circle class="nexus-node" cx="490" cy="471" r="25"/>
						</g>
					</g>
					<g id="Layer_x0020_3">
						<path class="fil1" d="M0 442l825 914 -1 82 -768 -852 0 859 -56 0 0 -1003zm239 845l-56 0 0 -480 56 52 0 428zm347 -1022l55 0 0 564 -55 -52 0 -512zm239 929l-825 -914 1 -82 768 852 0 -949 56 0 0 1093z"/>
					</g>
				</svg>
			</div>
			<h1 class="brand-name">NEXUS</h1>
			<p class="tagline">TECHNICAL DESIGN & CREATIVE SYSTEMS</p>
		</header>		

	<section class="expertise">
		<p>{expertiseStory}</p>
	</section>

	<div class="portfolio-grid">
			{pillarsWithContent.map(pillar => {
				const getAccent = (title) => {
					if (title.includes("Brand") || title.includes("Publication")) return "var(--pillar-red)";
					if (title.includes("Web") || title.includes("Digital")) return "var(--pillar-teal)";
					if (title.includes("Technical") || title.includes("Environmental")) return "var(--pillar-blue)";
					return "var(--pillar-blue)";
				};

				const accent = getAccent(pillar.data.title);

				return (
					<a href={`/pillars/${pillar.id}`} style="text-decoration: none; color: inherit;">
						<div class="pillar-card" style={`border-left: 2px solid ${accent}`}>
							<span class="pillar-category" style={`color: ${accent}`}>
								{pillar.data.title.toUpperCase()}
							</span>
							<h3>{pillar.data.focus}</h3>
							<div class="content">
								<pillar.Content />
							</div>
						</div>
					</a>
				);
			})}
		</div>
		<section class="audit-cta">
			<h3>READY TO ENGINEER YOUR SYSTEM?</h3>
			<p>Every brand requires a stable, logical foundation. Let's perform a technical audit of your current visual assets and infrastructure.</p>
			<a href="mailto:your@email.com" class="audit-button">REQUEST SYSTEM AUDIT</a>
		</section>
</MainLayout>