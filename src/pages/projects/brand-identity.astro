---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/MainLayout.astro';

// 1. Fetch the specific entry
const brandEntry = await getEntry('pillars', 'brand-identity');
const { Content } = await brandEntry.render();
---

<Layout title={`${brandEntry.data.title} | NEXUS Case Study`}>
  <article class="case-study">
    <h1>{brandEntry.data.title}</h1>
    <p class="subtitle">{brandEntry.data.focus}</p>

    <section class="overview">
      <h2>The Goal</h2>
      <Content /> 
    </section>

    <section class="featured-work">
      <h2>Featured Clients & Projects</h2>
      <p>{brandEntry.body}</p> 
    </section>
    
    <section class="tags">
      {brandEntry.data.tags.map(tag => <span>#{tag} </span>)}
    </section>
  </article>
</Layout>